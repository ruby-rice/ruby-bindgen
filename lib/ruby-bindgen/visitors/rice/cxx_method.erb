<%- if cursor.static? -%>
<%= is_template ? "template " : "" %>define_singleton_function<%= signature ? signature : "" %>("<%= name %>", &<%= cursor.semantic_parent.qualified_display_name %>::<%= cursor.spelling %>)
<%- else -%>
<%= is_template ? "template " : "" %>define_method<%= signature ? signature : "" %>("<%= name %>", &<%= cursor.semantic_parent.qualified_display_name %>::<%= cursor.spelling %>)
<%- end -%>